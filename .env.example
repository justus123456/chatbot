FLASK_ENV=development
SECRET_KEY=change-me
FLASK_SECRET_KEY=change-me
FRONTEND_URL=http://localhost:3000
FLASK_API_URL=http://localhost:5000

# Main AI provider for chat generation in the fresh build.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings can stay on Ollama even when chat generation uses Groq.
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=180

# WhatsApp Business API configuration.
WHATSAPP_VERIFY_TOKEN=veritas-whatsapp-202
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
REDIS_URL=memory://

# Backend Supabase credentials.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=student-resources

APP_NAME=Veritas AI Student Assistant
APP_LOCALE_DEFAULT=en
ALLOW_DEMO_AUTH=false
